{"openapi":"3.0.0","info":{"version":"1.0.0","description":"API documentation for SeaNeB project","title":"SeaNeB Web API Documentation"},"servers":[{"url":"https://dev.seaneb.com","description":"API Server"}],"components":{"securitySchemes":{"bearerAuth":{"type":"http","scheme":"bearer","bearerFormat":"JWT"},"ProductKey":{"type":"apiKey","in":"header","name":"x-product-key"}}},"security":[{"bearerAuth":[],"ProductKey":[]}],"paths":{"/api/v1/user/signup":{"post":{"summary":"User signup (Mobile mandatory, Email optional)","description":"Creates a new user after OTP verification.\n- Mobile OTP verification is mandatory. - Email is optional. - If email is provided, Email OTP verification is required.\nReturns access_token and csrf_token in response. Refresh token is stored automatically in an httpOnly cookie.\n","tags":["Auth"],"requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["country_code","mobile_number","first_name","last_name","dob","seaneb_id","place_id","product_key"],"properties":{"country_code":{"type":"string","example":"91"},"mobile_number":{"type":"string","example":"7874638498"},"first_name":{"type":"string","example":"Savan"},"last_name":{"type":"string","example":"Thakrar"},"email":{"type":"string","nullable":true,"example":"savan@email.com","description":"Optional. If provided, must be verified via Email OTP."},"dob":{"type":"string","format":"date","example":"1999-06-15"},"seaneb_id":{"type":"string","example":"savan-123"},"place_id":{"type":"string","example":"ChIJD98cx4rJWTkRO62Tvs8V3XY"},"product_key":{"type":"string","example":"seaneb"},"gender":{"type":"string","enum":["male","female","other"],"example":"male"}}}}}},"responses":{"201":{"description":"User created successfully"},"400":{"description":"Validation error or OTP not verified"},"409":{"description":"Email, mobile or Seaneb ID already exists"},"500":{"description":"Internal server error"}}}},"/api/v1/seanebid/check":{"post":{"summary":"Check Seaneb username availability","tags":["Auth"],"requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["seaneb_id"],"properties":{"seaneb_id":{"type":"string","example":"neel-desai"}}}}}},"responses":{"200":{"description":"Username available and reserved"},"400":{"description":"Invalid username"},"409":{"description":"Username already exists"}}}},"/api/v1/auth/refresh":{"post":{"summary":"Refresh access token","description":"Generates a new access token using refresh token stored in httpOnly cookie. Requires x-csrf-token header for CSRF protection.\n","tags":["Auth"],"parameters":[{"in":"header","name":"x-csrf-token","required":true,"schema":{"type":"string"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["product_key"],"properties":{"product_key":{"type":"string","example":"seaneb"}}}}}},"responses":{"200":{"description":"Access token refreshed successfully"},"400":{"description":"Product key missing or CSRF token missing"},"401":{"description":"Session expired or invalid refresh token"}}}},"/api/v1/business/autocomplete":{"get":{"summary":"Business name autocomplete (Google Places)","description":"Returns business suggestions based on user input. Only establishments (company/shop names) are returned. Requires minimum 2 characters.\n","tags":["Business"],"security":[{"bearerAuth":[]}],"parameters":[{"in":"header","name":"x-product-key","required":true,"schema":{"type":"string"},"description":"Product key context","example":"seaneb"},{"in":"query","name":"input","required":true,"schema":{"type":"string"},"description":"Minimum 2 characters of business name","example":"zar"}],"responses":{"200":{"description":"Business suggestions fetched successfully","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean","example":true},"businesses":{"type":"array","items":{"type":"object","properties":{"description":{"type":"string","example":"Zara - Ahmedabad One Mall"},"place_id":{"type":"string","example":"ChIJxxxxxxxxxxxx"}}}}}}}}},"400":{"description":"Invalid input or Product key missing"},"401":{"description":"Unauthorized"},"500":{"description":"Failed to fetch suggestions"}}}},"/api/v1/business/create":{"post":{"summary":"Create business with default branch","description":"Creates a new business and automatically creates one default branch. Fresh mobile OTP verification is mandatory.\nPAN and GST are optional. If provided, they are LIVE verified using Cashfree.\nEmail verification is required only if email is provided.\n","tags":["Business"],"security":[{"bearerAuth":[]}],"parameters":[{"in":"header","name":"x-product-key","required":true,"schema":{"type":"string"},"description":"Product key mapped with JWT product_id"}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["business_name","display_name","main_category_id","seaneb_id","primary_number","place_id"],"properties":{"business_name":{"type":"string","example":"Seaneb Technology Pvt Ltd"},"display_name":{"type":"string","example":"Seaneb Tech"},"main_category_id":{"type":"string","example":"3803ffd2-2f5d-4cec-a121-9f1007c2c2dd"},"seaneb_id":{"type":"string","example":"seaneb-techno12"},"primary_number":{"type":"string","example":"9427370115"},"whatsapp_number":{"type":"string","nullable":true},"business_email":{"type":"string","nullable":true},"about_branch":{"type":"string","example":"Head office branch"},"address":{"type":"string","nullable":true},"landmark":{"type":"string","nullable":true},"place_id":{"type":"string","example":"ChIJbU60yXAWrjsR4E9-UejD3_g"},"pan":{"type":"object","nullable":true,"properties":{"pan_number":{"type":"string","example":"ABCDE1234F"}}},"gst":{"type":"object","nullable":true,"properties":{"gstin":{"type":"string","example":"24ABCDE1234F1Z5"}}}}}}}},"responses":{"201":{"description":"Business and default branch created successfully"},"400":{"description":"Validation error"},"401":{"description":"Unauthorized"},"409":{"description":"Duplicate business or Seaneb ID"}}}},"/api/v1/business/create-branch":{"post":{"summary":"Create new branch under existing business","description":"Creates a new branch under an ACTIVE business.\nRequirements: - Access token required - business_id must belong to logged-in user - product_key is required - PAN verification is COMPULSORY - GST verification is COMPULSORY\nEmail verification required only if email is provided. WhatsApp OTP required only if different from primary.\n","tags":["Business"],"security":[{"bearerAuth":[]}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["business_id","product_key","seaneb_id","primary_number","place_id","pan","gst"],"properties":{"business_id":{"type":"string","example":"e0e46335-7b3b-46b4-aeca-e579cedcdb7f"},"product_key":{"type":"string","example":"seaneb"},"seaneb_id":{"type":"string","example":"seaneb-branch02"},"primary_number":{"type":"string","example":"9427370115"},"whatsapp_number":{"type":"string","nullable":true},"business_email":{"type":"string","nullable":true},"about_branch":{"type":"string","example":"Second branch"},"address":{"type":"string","nullable":true},"landmark":{"type":"string","nullable":true},"place_id":{"type":"string","example":"ChIJbU60yXAWrjsR4E9-UejD3_g"},"pan":{"type":"object","required":["pan_number"],"properties":{"pan_number":{"type":"string","example":"ABCDE1234F"}}},"gst":{"type":"object","required":["gstin"],"properties":{"gstin":{"type":"string","example":"24ABCDE1234F1Z5"}}}}}}}},"responses":{"201":{"description":"Branch created successfully"},"400":{"description":"Validation error"},"401":{"description":"Unauthorized"},"403":{"description":"Business not owned by user"},"409":{"description":"Duplicate Seaneb ID or primary number"}}}},"/api/v1/verification/verify-pan":{"post":{"summary":"Verify PAN using Cashfree","tags":["Verification"],"security":[{"bearerAuth":[]}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["pan_number","branch_id"],"properties":{"pan_number":{"type":"string","example":"ABCDE1234F"},"branch_id":{"type":"string"}}}}}},"responses":{"200":{"description":"PAN verified successfully"}}}},"/api/v1/verification/verify-gst":{"post":{"summary":"Verify GSTIN using Cashfree","tags":["Verification"],"security":[{"bearerAuth":[]}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["gstin","branch_id"],"properties":{"gstin":{"type":"string","example":"24ABCDE1234F1Z5"},"branch_id":{"type":"string"}}}}}},"responses":{"200":{"description":"GST verified successfully"}}}},"/api/v1/location/{product_key}/countries":{"get":{"summary":"Get list of countries for a product","description":"Returns all countries where active businesses are registered under the specified product.\nProduct-specific filtering is applied using business_products mapping.\n","tags":["Listing"],"parameters":[{"in":"path","name":"product_key","required":true,"schema":{"type":"string"},"description":"Product identifier (e.g., seaneb_property)"}],"responses":{"200":{"description":"Countries fetched successfully"},"404":{"description":"Product not found"}}}},"/api/v1/location/{product_key}/{country_slug}/states":{"get":{"summary":"Get states under a country for a product","description":"Returns all states under the given country where businesses are registered for the specified product.\n","tags":["Listing"],"parameters":[{"in":"path","name":"product_key","required":true,"schema":{"type":"string"},"description":"Product identifier"},{"in":"path","name":"country_slug","required":true,"schema":{"type":"string"},"description":"Country slug (e.g., india)"}],"responses":{"200":{"description":"States fetched successfully"},"404":{"description":"Country or product not found"}}}},"/api/v1/location/{product_key}/{country_slug}/{state_slug}/cities":{"get":{"summary":"Get cities under a state for a product","description":"Returns cities under the specified state where businesses are registered for the given product.\n","tags":["Listing"],"parameters":[{"in":"path","name":"product_key","required":true,"schema":{"type":"string"}},{"in":"path","name":"country_slug","required":true,"schema":{"type":"string"}},{"in":"path","name":"state_slug","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"Cities fetched successfully"},"404":{"description":"State or product not found"}}}},"/api/v1/location/{product_key}/{country_slug}/{state_slug}/{city_slug}/areas":{"get":{"summary":"Get areas under a city (Only for area-level products)","description":"Returns areas under the specified city.\nThis API only returns data for products configured as area-level hierarchy (e.g., seaneb_property, seaneb_news, seaneb_tiffin).\nFor other products, this will return an empty array.\n","tags":["Listing"],"parameters":[{"in":"path","name":"product_key","required":true,"schema":{"type":"string"}},{"in":"path","name":"country_slug","required":true,"schema":{"type":"string"}},{"in":"path","name":"state_slug","required":true,"schema":{"type":"string"}},{"in":"path","name":"city_slug","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"Areas fetched successfully"}}}},"/api/v1/location/{product_key}/{country_slug}/{state_slug}/{city_slug}/businesses":{"get":{"summary":"Get businesses by city (City-level products)","description":"Returns businesses under the specified city.\nThis API applies to products that do NOT use area-level hierarchy. Example: general products where businesses are grouped directly by city.\n","tags":["Listing"],"parameters":[{"in":"path","name":"product_key","required":true,"schema":{"type":"string"}},{"in":"path","name":"country_slug","required":true,"schema":{"type":"string"}},{"in":"path","name":"state_slug","required":true,"schema":{"type":"string"}},{"in":"path","name":"city_slug","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"Businesses fetched successfully"}}}},"/api/v1/location/{product_key}/{country_slug}/{state_slug}/{city_slug}/{area_slug}/businesses":{"get":{"summary":"Get businesses by area (Area-level products)","description":"Returns businesses under the specified area.\nThis API applies only to area-level products such as: - seaneb_property - seaneb_news - seaneb_tiffin\nProduct filtering is applied automatically.\n","tags":["Listing"],"parameters":[{"in":"path","name":"product_key","required":true,"schema":{"type":"string"}},{"in":"path","name":"country_slug","required":true,"schema":{"type":"string"}},{"in":"path","name":"state_slug","required":true,"schema":{"type":"string"}},{"in":"path","name":"city_slug","required":true,"schema":{"type":"string"}},{"in":"path","name":"area_slug","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"Businesses fetched successfully"}}}},"/api/v1/location/{product_key}/business/{seaneb_id}":{"get":{"summary":"Get business detail by Seaneb ID","description":"Returns complete business details including: - Business information - Branch contact details - Location hierarchy (Area → City → State → Country)\nProduct-specific filtering is automatically applied. If the business is not registered under the given product, this API will return an error.\nUniversal products (e.g., jobs) bypass product registration filtering.\n","tags":["Listing"],"parameters":[{"in":"path","name":"product_key","required":true,"schema":{"type":"string"},"description":"Product identifier (e.g., seaneb_property)"},{"in":"path","name":"seaneb_id","required":true,"schema":{"type":"string"},"description":"Unique Seaneb identifier of the business (e.g., gujarat-club)"}],"responses":{"200":{"description":"Business details fetched successfully","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"data":{"type":"object"}}}}}},"404":{"description":"Business not found or not registered under this product"}}}},"/api/v1/autocomplete-cities":{"get":{"summary":"City autocomplete","description":"Returns city suggestions using Google Places Autocomplete API","tags":["Location"],"parameters":[{"in":"query","name":"input","required":true,"schema":{"type":"string","minLength":2},"description":"Minimum 2 characters required for autocomplete search","example":"ahm"}],"responses":{"200":{"description":"Autocomplete results fetched successfully"},"400":{"description":"Input is missing or less than 2 characters"},"500":{"description":"Internal server error"}}}},"/api/v1/cities":{"get":{"summary":"Get city list","tags":["Location"],"parameters":[{"in":"query","name":"search","schema":{"type":"string"},"example":"ahm"},{"in":"query","name":"limit","schema":{"type":"integer"},"example":20}],"responses":{"200":{"description":"City list fetched successfully"}}}},"/api/v1/business/area-autocomplete":{"get":{"summary":"Area Level Business Autocomplete","description":"Returns business suggestions restricted within a 5KM radius. User only needs to type search text. Area detection is handled automatically.\n","tags":["Business"],"parameters":[{"in":"query","name":"input","required":true,"schema":{"type":"string","minLength":2},"example":"ashok"}],"responses":{"200":{"description":"Area autocomplete results fetched successfully"},"400":{"description":"Invalid input"},"500":{"description":"Internal server error"}}}},"/api/v1/otp/send-otp":{"post":{"summary":"Send OTP","description":"Sends OTP to mobile number.\nPurpose usage: - 0 = Signup (user registration) - 1 = Login - 2 = Business mobile verification (before create business) - 4 = User profile update - 5 = Business profile update\n","tags":["OTP"],"requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["identifier_type","purpose"],"properties":{"identifier_type":{"type":"integer","description":"0 = mobile, 1 = email","default":0},"country_code":{"type":"string","example":"91","description":"Required when identifier_type = 0"},"mobile_number":{"type":"string","example":"8160026509","description":"Required when identifier_type = 0"},"purpose":{"type":"integer","description":"OTP purpose: 0 = signup, 1 = login, 2 = business mobile verification, 4 = user profile update, 5 = business profile update\n","example":0},"via":{"type":"string","enum":["sms","whatsapp"],"default":"whatsapp"}}}}}},"responses":{"200":{"description":"OTP sent successfully"},"400":{"description":"Invalid request"},"429":{"description":"Too many requests"}}}},"/api/v1/otp/verify-otp":{"post":{"summary":"Verify OTP","description":"Verifies OTP sent to mobile number.\nThis API is used for: - User signup verification - User login verification - Business mobile verification (mandatory before create business)\n","tags":["OTP"],"requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["identifier_type","otp","purpose","product_key"],"properties":{"identifier_type":{"type":"integer","description":"0 = mobile, 1 = email","default":0},"country_code":{"type":"string","example":"91","description":"Required when identifier_type = 0"},"mobile_number":{"type":"string","example":"8160026509","description":"Required when identifier_type = 0"},"otp":{"type":"string","example":"8679"},"purpose":{"type":"integer","description":"0 = signup, 1 = login, 2 = business mobile verification\n","example":0},"product_key":{"type":"string","example":"seaneb","description":"Product identifier key"}}}}}},"responses":{"200":{"description":"OTP verified successfully"},"400":{"description":"Invalid OTP"},"429":{"description":"Too many attempts"}}}},"/api/v1/auth/email/send-otp":{"post":{"summary":"Send Email OTP","description":"Sends OTP to email address.\nPurpose usage: - 1 = User signup email verification - 3 = Business email verification (before create business)\n","tags":["OTP"],"requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["email","purpose"],"properties":{"email":{"type":"string","example":"savan@test.com"},"purpose":{"type":"integer","description":"1 = signup email verification, 3 = business email verification\n","example":1}}}}}},"responses":{"200":{"description":"Email OTP sent successfully"},"400":{"description":"Invalid request"},"429":{"description":"Too many requests"}}}},"/api/v1/auth/email/verify-otp":{"post":{"summary":"Verify Email OTP","description":"Verifies OTP sent to email.\nPurpose usage: - 1 = User signup email verification - 3 = Business email verification\n","tags":["OTP"],"requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["email","otp","purpose"],"properties":{"email":{"type":"string","example":"savan@test.com"},"otp":{"type":"string","example":"1234"},"purpose":{"type":"integer","description":"1 = signup email verification, 3 = business email verification\n","example":1}}}}}},"responses":{"200":{"description":"Email verified successfully"},"400":{"description":"Invalid or expired OTP"}}}},"/api/v1/payment/onboarding-payment":{"post":{"summary":"Create branch onboarding payment","tags":["Payment"],"security":[{"bearerAuth":[]},{"ProductKey":[]}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["branch_id"],"properties":{"branch_id":{"type":"string","format":"uuid","example":"d9bdbcf1-6d36-49df-b5cf-51f752c35dbb"}}}}}},"responses":{"200":{"description":"Payment order created successfully","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean","example":true},"message":{"type":"string","example":"Onboarding payment order created successfully"},"payment_session_id":{"type":"string","example":"session_xxxxxx"},"order_id":{"type":"string","example":"onboard_1739701234567"},"amount":{"type":"number","example":118},"payment_id":{"type":"string","example":"9f5c9a12-3456-7890-abcd-123456789abc"}}}}}},"400":{"description":"Invalid request"},"401":{"description":"Unauthorized"},"404":{"description":"Branch or product not found"},"500":{"description":"Internal server error"}}}},"/api/v1/payment/webhook":{"post":{"summary":"Cashfree webhook endpoint","tags":["Payment"],"description":"Receives payment status updates from Cashfree","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","example":{"type":"PAYMENT_SUCCESS_WEBHOOK","data":{"order":{"order_id":"onboard_1739701234567","order_status":"PAID"},"payment":{"cf_payment_id":1234567890}}}}}}},"responses":{"200":{"description":"Webhook processed successfully"},"400":{"description":"Invalid signature"},"404":{"description":"Payment not found"},"500":{"description":"Internal server error"}}}},"/api/v1/profile/me":{"get":{"summary":"Get logged-in user profile","description":"Fetches the authenticated user's profile details including full name, SeaNeb ID, profile photo, and business registration status. User must be logged in with a valid access token and product key.\n","tags":["User"],"security":[{"bearerAuth":[]}],"parameters":[{"in":"header","name":"x-product-key","required":true,"schema":{"type":"string"},"description":"Unique product key required for authentication context."}],"responses":{"200":{"description":"Profile details retrieved successfully","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean","example":true},"data":{"type":"object","properties":{"full_name":{"type":"string","example":"Bharat Parmar"},"seaneb_id":{"type":"string","example":"bharat-p-123"},"profile_photo":{"type":"string","example":"https://api.seanebjobs.com/assets/default-user.png"},"is_business_registered":{"type":"boolean","example":true,"description":"Indicates if the user has an active business/branch registration."}}}}}}}},"401":{"description":"Unauthorized - Valid login token and active session are required"},"403":{"description":"Forbidden - Invalid or inactive product key provided"},"404":{"description":"User not found"},"500":{"description":"Internal server error"}}}},"/api/v1/logout":{"post":{"tags":["User"],"summary":"Logout","description":"Invalidates  sessions for the user across  ( .com and .app). The backend extracts the `user_id` from the secure `refresh_token` cookie. This ensures that even if an access token has time remaining, it will be rejected by the authentication middleware due to the mandatory database status check.\n","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["product_key"],"properties":{"product_key":{"type":"string","description":"The identifier for the product .","example":"jobs"}}}}}},"responses":{"200":{"description":"Logout successful."},"400":{"description":"Bad Request. Missing product_key."},"401":{"description":"Unauthorized. No valid refresh token cookie present."},"500":{"description":"Internal Server Error."}},"security":[{"cookieAuth":[]}]}},"/api/v1/sso/exchange":{"post":{"tags":["SSO"],"summary":"Exchange a bridge token for a product-specific session","description":"Verifies the short-lived bridge token and establishes a new session for the target product.\n","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["bridge_token","target_product_key"],"properties":{"bridge_token":{"type":"string","description":"A short-lived token used for authentication."},"target_product_key":{"type":"string","description":"The key of the product user is navigating to (e.g., 'jobs')."}}}}}},"responses":{"200":{"description":"Session successfully established for the target product."},"401":{"description":"Unauthorized - Bridge token is invalid, expired, or purpose mismatch."},"404":{"description":"Product Not Found - The target_product_key does not exist or is inactive."},"500":{"description":"Internal Server Error - Issues with database transaction or token signing."}}}}},"tags":[{"name":"Payment","description":"Business Onboarding Payment APIs"}]}
